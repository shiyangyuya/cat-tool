{
  "name": "cat-tool",
  "version": "0.0.3",
  "description": "a web development tool library",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "author": "shiyangyuya@gmail.com",
  "license": "MIT",
  "directories": {
    "doc": "docs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "preCommit": "npm run build",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiyangyuya/cat-tool.git"
  },
  "keywords": [
    "bus",
    "indexedDB",
    "watermark",
    "location",
    "uuid",
    "memoize"
  ],
  "bugs": {
    "url": "https://github.com/shiyangyuya/cat-tool/issues"
  },
  "homepage": "https://shiyangyuya.github.io/cat-tool/zh",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.11",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.1",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitepress": "^1.3.1"
  },
  "lint-staged": {
    "*.{ts,js,json,md,vue}": [
      "prettier --write"
    ]
  }
}
